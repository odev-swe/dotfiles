# ==============================================================================
# Homebrew (Apple Silicon / Intel)
# ==============================================================================
{{- if eq .chezmoi.arch "arm64" }}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{- else }}
eval "$(/usr/local/bin/brew shellenv)"
{{- end }}

# ==============================================================================
# Zinit Plugin Manager
# ==============================================================================
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"

if [[ ! -d "$ZINIT_HOME" ]]; then
    mkdir -p "$(dirname "$ZINIT_HOME")"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

source "${ZINIT_HOME}/zinit.zsh"

# ------------------------------------------------------------------------------
# Plugins
# ------------------------------------------------------------------------------
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit light zsh-users/zsh-autosuggestions
zinit light Aloxaf/fzf-tab

# ------------------------------------------------------------------------------
# OMZ snippets (without Oh My Zsh)
# ------------------------------------------------------------------------------
zinit snippet OMZL::git.zsh
zinit snippet OMZP::git
zinit snippet OMZP::aws
zinit snippet OMZP::kubectl
zinit snippet OMZP::kubectx
zinit snippet OMZP::helm
zinit snippet OMZP::fluxcd

# ------------------------------------------------------------------------------
# Completions
# ------------------------------------------------------------------------------
autoload -Uz compinit
compinit -d ~/.cache/zcompdump
zinit cdreplay -q

# kubectl completion: OMZP::kubectl generates _kubectl in background, losing the
# compinit race. Source it directly so `k`/`kubectl` tab-complete deterministically.
if command -v kubectl >/dev/null; then
  source <(kubectl completion zsh)
  compdef k=kubectl
fi

# ==============================================================================
# Keybindings
# ==============================================================================
bindkey -e

# type keyword, then Up/Down filters history to commands starting with it
autoload -U up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey '^[[A' up-line-or-beginning-search
bindkey '^[[B' down-line-or-beginning-search

bindkey '^p' history-search-backward
bindkey '^n' history-search-forward
bindkey '^[[1;5C' forward-word
bindkey '^[[1;5D' backward-word
bindkey '^[[1;3C' forward-word
bindkey '^[[1;3D' backward-word
bindkey '^[w' kill-region
bindkey '^[[H' beginning-of-line
bindkey '^[[F' end-of-line
bindkey '^[[3~' delete-char
bindkey '^?' backward-delete-char

# ==============================================================================
# History
# ==============================================================================
HISTSIZE=5000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE

setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups
setopt auto_cd
setopt interactive_comments
setopt complete_in_word
setopt auto_menu

# ==============================================================================
# Completion Styling
# ==============================================================================
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*:git-checkout:*' sort false

zstyle ':fzf-tab:*' switch-group ',' '.'
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza --icons --color=always $realpath'
zstyle ':fzf-tab:complete:__zoxide_z:*' fzf-preview 'eza --icons --color=always $realpath'

# ==============================================================================
# PATH
# ==============================================================================
export PATH="$HOME/bin:$PATH"

# ==============================================================================
# Claude / AWS
# ==============================================================================
export CLAUDE_CODE_USE_BEDROCK=1
export AWS_REGION={{ .aws.region | quote }}
export AWS_PROFILE={{ .aws.profile | quote }}

# ==============================================================================
# Mise
# ==============================================================================
eval "$(mise activate zsh)"

# ==============================================================================
# Starship
# ==============================================================================
eval "$(starship init zsh)"

# ==============================================================================
# Zoxide
# ==============================================================================
eval "$(zoxide init zsh --cmd cd)"

# ==============================================================================
# fzf (Ctrl+R fuzzy history, Ctrl+T file, Alt+C cd)
# ==============================================================================
source <(fzf --zsh)

# ==============================================================================
# Aliases
# ==============================================================================
alias ca='bw_unlock && bw sync --force && chezmoi apply --force --verbose && source ~/.zshrc'
alias claude-sync='chezmoi re-add'
alias vim='nvim'
alias zshs='source ~/.zshrc'
alias macclean='~/.local/bin/macclean'

# ls → eza
alias ls='eza --icons --group-directories-first'
alias ll='eza -l --icons --group-directories-first --git'
alias la='eza -la --icons --group-directories-first --git'
alias lt='eza --tree --level=2 --icons'

# misc
alias cat='bat'
alias lg='lazygit'
alias ..='cd ..'
alias ...='cd ../..'
alias k='kubectl'

# Claude Code context functions
cc() {
  CLAUDE_CODE_USE_BEDROCK=1 AWS_REGION={{ .aws.region | quote }} AWS_PROFILE={{ .aws.profile | quote }} claude "$@"
}

cc-enterprise() {
  env -u CLAUDE_CODE_USE_BEDROCK -u AWS_REGION -u AWS_PROFILE claude "$@"
}

# ==============================================================================
# Functions
# ==============================================================================
vpn() {
  sudo "$(command -v openfortivpn)" -c ~/.config/openfortivpn/config "$@"
}

# ==============================================================================
# Bitwarden Helpers
# ==============================================================================
bw_unlock() {
  local cache="${XDG_STATE_HOME:-$HOME/.local/state}/bw/session"

  _bw_session_valid() {
    local token="$1"
    [[ -n "$token" ]] || return 1
    BW_SESSION="$token" bw status 2>/dev/null | grep -q '"status":"unlocked"'
  }

  if _bw_session_valid "$BW_SESSION"; then
    return 0
  fi

  if [[ -r "$cache" ]]; then
    local cached
    cached="$(<"$cache")"
    if _bw_session_valid "$cached"; then
      export BW_SESSION="$cached"
      return 0
    fi
  fi

  local token
  token="$(bw unlock --raw)" || return 1
  export BW_SESSION="$token"

  mkdir -p "$(dirname "$cache")"
  ( umask 077 && printf '%s' "$token" > "$cache" )
}

bw_lock() {
  bw lock >/dev/null 2>&1 || true
  unset BW_SESSION
  rm -f "${XDG_STATE_HOME:-$HOME/.local/state}/bw/session"
}

chezmoi() {
  case "${1:-}" in
    apply|diff|update|init|re-add|verify|merge-all|execute-template)
      bw_unlock || return $?
      ;;
  esac
  command chezmoi "$@"
}

full_update() {
  softwareupdate --install --all
  brew update && brew upgrade && brew cleanup
  mise upgrade
  chezmoi upgrade
}

# ==============================================================================
# nvm (Node Version Manager)
# ==============================================================================
export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"
