{{/* Prompts run once on `chezmoi init`; answers land in ~/.config/chezmoi/chezmoi.toml */ -}}
{{- $name    := promptStringOnce . "name" "Full name" "odev" -}}
{{- $email   := promptStringOnce . "email" "Git email" "odev@example.com" -}}
{{- $profile := promptStringOnce . "aws.profile" "Default AWS profile" "risk-ai" -}}
{{- $region  := promptStringOnce . "aws.region" "Default AWS region" "ap-southeast-5" -}}
{{- $work    := promptBoolOnce   . "work" "Is this a work machine?" true -}}

[data]
    name  = {{ $name | quote }}
    email = {{ $email | quote }}
    work  = {{ $work }}

    [data.aws]
        profile = {{ $profile | quote }}
        region  = {{ $region | quote }}
